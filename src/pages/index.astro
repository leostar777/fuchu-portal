---
import news from '../../data/news.json' assert { type: 'json' };
const { top, fuchu } = news;
let shown = 13;               // 初期表示 13
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>ふちゅぽ – 府中市ポータル</title>
    <link rel="stylesheet" href="/fuchu-portal/styles.css" />
  </head>
  <body>
    <div class="container">
      <header>
        <h1>ふちゅぽ – 府中市ポータル</h1>
        <p>府中市の最新情報をお届けします</p>
      </header>
      
      <main>
        <!-- ▼ 主要ニュース（7 件） -->
        <section class="news-section">
          <h2>主要ニュース</h2>
          <div class="news-list">
            {top.map((n: any, i: number) => (
              <article class="news-item">
                <h3><a href={n.link} target="_blank">{i+1}. {n.title}</a></h3>
                <time class="news-time">{n.formatted}</time>
              </article>
            ))}
          </div>
        </section>

        <!-- ▼ 府中ニュース（13 件 + もっと見る） -->
        <section class="news-section">
          <h2>府中ニュース</h2>
          <div id="fuchu" class="news-list">
            {fuchu.slice(0, shown).map((n: any, i: number) => (
              <article class="news-item">
                <h3><a href={n.link} target="_blank">{i+1}. {n.title}</a></h3>
                <time class="news-time">{n.formatted}</time>
              </article>
            ))}
          </div>
          <button id="more" class="more-btn">もっと見る</button>
        </section>
      </main>
      
      <footer>
        <p>&copy; 2025 ふちゅぽ – 府中市ポータル</p>
      </footer>
    </div>
    <script type="module">
      const all = JSON.parse('{JSON.stringify(fuchu)}');
      let shown = 13;
      document.getElementById('more').addEventListener('click', () => {
        shown += 10;
        const list = document.getElementById('fuchu');
        list.innerHTML = all.slice(0, shown).map((n,i)=>`
          <article class="news-item">
            <h3><a href="${n.link}" target="_blank">${i+1}. ${n.title}</a></h3>
            <time class="news-time">${n.formatted}</time>
          </article>`).join('');
        
        if (shown >= all.length) {
          document.getElementById('more').style.display = 'none';
        }
      });
    </script>
  </body>
</html>
